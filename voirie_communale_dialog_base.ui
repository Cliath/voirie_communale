<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>VoirieCommunaleDialogBase</class>
 <widget class="QDialog" name="VoirieCommunaleDialogBase">
    <property name="geometry">
     <rect>
      <x>0</x>
      <y>0</y>
      <width>400</width>
      <height>380</height>
     </rect>
    </property>
  <property name="windowTitle">
   <string>Voirie Communale - Recensement</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="QLabel" name="label">
     <property name="text">
      <string>Recensement de la voirie communale</string>
     </property>
     <property name="alignment">
      <set>Qt::AlignCenter</set>
     </property>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="groupBoxCadastre">
     <property name="title">
      <string>Données géographiques</string>
     </property>
     <layout class="QVBoxLayout" name="verticalLayout_2">
      <item>
       <layout class="QHBoxLayout" name="horizontalLayout">
        <item>
         <widget class="QLabel" name="labelCodeInsee">
          <property name="text">
           <string>Code INSEE :</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QLineEdit" name="txtCodeInsee">
          <property name="toolTip">
           <string>Code INSEE de la commune (5 caractères : département + commune)</string>
          </property>
          <property name="placeholderText">
           <string>Ex: 75056 (Paris), 2A004 (Ajaccio)</string>
          </property>
          <property name="maxLength">
           <number>5</number>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <widget class="QCheckBox" name="chkToutSelectionner">
        <property name="text">
         <string>Tout sélectionner / Désélectionner</string>
        </property>
        <property name="styleSheet">
         <string>color: #555; font-style: italic;</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="labelChoixCouches">
        <property name="text">
         <string>Données à charger :</string>
        </property>
        <property name="styleSheet">
         <string>font-weight: bold; margin-top: 10px;</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QTabWidget" name="tabWidgetDonnees">
        <property name="currentIndex">
         <number>0</number>
        </property>
        <!-- Onglet Nationales -->
        <widget class="QWidget" name="tabNationales">
         <attribute name="title">
          <string>Nationales</string>
         </attribute>
         <layout class="QVBoxLayout" name="layoutNationales">
          <property name="spacing"><number>4</number></property>
          <property name="leftMargin"><number>8</number></property>
          <property name="topMargin"><number>6</number></property>
          <property name="rightMargin"><number>8</number></property>
          <property name="bottomMargin"><number>6</number></property>
          <item>
           <widget class="QCheckBox" name="chkCommune">
            <property name="text">
             <string>Emprise communale (Admin Express IGN)</string>
            </property>
            <property name="toolTip">
             <string>Charge le contour de la commune (Admin Express COG IGN) filtré sur le code INSEE saisi&#10;Licence Ouverte 2.0 (Etalab) — © IGN</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkBDTopoRoutesNom">
            <property name="text">
             <string>Routes numérotées ou nommées (BD TOPO® IGN)</string>
            </property>
            <property name="toolTip">
             <string>Charge les routes numérotées ou nommées (BDTOPO_V3:route_numerotee_ou_nommee) filtrées sur l'emprise de la commune&#10;Licence Ouverte 2.0 (Etalab) — © IGN</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkBDTopoTroncons">
            <property name="text">
             <string>Tronçons de route (BD TOPO® IGN)</string>
            </property>
            <property name="toolTip">
             <string>Charge les tronçons de route (BDTOPO_V3:troncon_de_route) filtrés sur l'emprise de la commune, avec pagination&#10;Licence Ouverte 2.0 (Etalab) — © IGN</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkOsmRoutes">
            <property name="text">
             <string>Routes OSM (Overpass)</string>
            </property>
            <property name="toolTip">
             <string>Télécharge les routes OSM filtrées sur la commune&#10;© contributeurs OpenStreetMap — ODbL 1.0</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkMagOsm">
            <property name="text">
             <string>Réseau routier OSM (MagOSM)</string>
            </property>
            <property name="toolTip">
             <string>Charge le réseau routier OSM (magosm:highways_line) via le WFS MagOSM (Magellium), catégorisé par type highway&#10;© contributeurs OpenStreetMap — ODbL 1.0 | Service : Magellium MagOSM</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkVoirie">
            <property name="text">
             <string>Voirie communale (DGCL 2025)</string>
            </property>
            <property name="toolTip">
             <string>Charge le réseau de voirie communale (calcul IGN pour la DGCL)&#10;Licence Ouverte 2.0 (Etalab) — © IGN / DGCL</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkVoirieDep">
            <property name="text">
             <string>Voirie départementale (DGCL 2025)</string>
            </property>
            <property name="toolTip">
             <string>Charge le réseau de voirie départementale (calcul IGN pour la DGCL)&#10;Licence Ouverte 2.0 (Etalab) — © IGN / DGCL</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkBAN">
            <property name="text">
             <string>Adresses (Base Adresse Nationale - BAN)</string>
            </property>
            <property name="toolTip">
             <string>Charge toutes les adresses de la commune (peut être lent pour les grandes villes)&#10;Licence Ouverte 2.0 (Etalab) — © DINUM / collectivités</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkMajic">
            <property name="text">
             <string>Parcelles personnes morales (MAJIC)</string>
            </property>
            <property name="toolTip">
             <string>Charge les parcelles cadastrales détenues par des personnes morales (données DGFiP via Koumoul)&#10;Licence Ouverte 2.0 (Etalab) — © DGFiP</string>
            </property>
           </widget>
          </item>
          <item>
           <spacer name="spacerNationales">
            <property name="orientation"><enum>Qt::Vertical</enum></property>
            <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
           </spacer>
          </item>
         </layout>
        </widget>
        <!-- Onglet Locales -->
        <widget class="QWidget" name="tabLocales">
         <attribute name="title">
          <string>Locales</string>
         </attribute>
         <layout class="QVBoxLayout" name="layoutLocales">
          <property name="leftMargin"><number>8</number></property>
          <property name="topMargin"><number>6</number></property>
          <property name="rightMargin"><number>8</number></property>
          <property name="bottomMargin"><number>6</number></property>
          <item>
           <spacer name="spacerLocales">
            <property name="orientation"><enum>Qt::Vertical</enum></property>
            <property name="sizeHint" stdset="0"><size><width>0</width><height>40</height></size></property>
           </spacer>
          </item>
         </layout>
        </widget>
        <!-- Onglet Autres -->
        <widget class="QWidget" name="tabDonneesAutre">
         <attribute name="title">
          <string>Autres</string>
         </attribute>
         <layout class="QVBoxLayout" name="layoutDonneesAutre">
          <property name="leftMargin"><number>8</number></property>
          <property name="topMargin"><number>6</number></property>
          <property name="rightMargin"><number>8</number></property>
          <property name="bottomMargin"><number>6</number></property>
          <item>
           <spacer name="spacerDonneesAutre">
            <property name="orientation"><enum>Qt::Vertical</enum></property>
            <property name="sizeHint" stdset="0"><size><width>0</width><height>40</height></size></property>
           </spacer>
          </item>
         </layout>
        </widget>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="labelChoixPlans">
        <property name="text">
         <string>Plans à charger :</string>
        </property>
        <property name="styleSheet">
         <string>font-weight: bold; margin-top: 10px;</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QTabWidget" name="tabWidgetPlans">
        <property name="currentIndex">
         <number>0</number>
        </property>
        <!-- Onglet Actuels -->
        <widget class="QWidget" name="tabActuels">
         <attribute name="title">
          <string>Actuels</string>
         </attribute>
         <layout class="QVBoxLayout" name="layoutActuels">
          <property name="spacing">
           <number>4</number>
          </property>
          <property name="leftMargin"><number>8</number></property>
          <property name="topMargin"><number>6</number></property>
          <property name="rightMargin"><number>8</number></property>
          <property name="bottomMargin"><number>6</number></property>
          <item>
           <widget class="QCheckBox" name="chkCadastre">
            <property name="text">
             <string>Cadastre (10 couches : parcelles, bâtiments, lieux-dits, etc.)</string>
            </property>
            <property name="toolTip">
             <string>Charge les 10 couches du cadastre (parcelles, bâtiments, lieux-dits, sections, communes, subdivisions fiscales, etc.) via le WMS DGFiP&#10;Licence Ouverte 2.0 (Etalab) — © DGFiP</string>
            </property>
            <property name="checked">
             <bool>true</bool>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkPlanIGN">
            <property name="text">
             <string>PLAN IGN J+1</string>
            </property>
            <property name="toolTip">
             <string>Charge le PLAN IGN J+1 (GEOGRAPHICALGRIDSYSTEMS.MAPS.BDUNI.J1) via le WMS IGN Géoplateforme&#10;Licence Ouverte 2.0 (Etalab) — © IGN</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkBDOrtho">
            <property name="text">
             <string>BD ORTHO® 20 cm</string>
            </property>
            <property name="toolTip">
             <string>Charge la BD ORTHO® 20 cm (HR.ORTHOIMAGERY.ORTHOPHOTOS) via le WMS IGN Géoplateforme&#10;Licence Ouverte 2.0 (Etalab) — © IGN</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkMNTLidar">
            <property name="text">
             <string>MNT LiDAR HD</string>
            </property>
            <property name="toolTip">
             <string>Charge le MNT issu de LiDAR HD (IGNF_LIDAR-HD_MNT_ELEVATION.ELEVATIONGRIDCOVERAGE.SHADOW) via le WMS IGN Géoplateforme&#10;Licence Ouverte 2.0 (Etalab) — © IGN</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkOsmFR">
            <property name="text">
             <string>OSM France</string>
            </property>
            <property name="toolTip">
             <string>Charge les tuiles XYZ OpenStreetMap France comme fond de plan raster&#10;© contributeurs OpenStreetMap — ODbL 1.0</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkWazeTiles">
            <property name="text">
             <string>Waze</string>
            </property>
            <property name="toolTip">
             <string>Charge les tuiles XYZ Waze Editor (routes) comme fond de plan raster&#10;© Waze — usage non commercial uniquement</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkCoSIA">
            <property name="text">
             <string>CoSIA (Couverture du Sol par IA)</string>
            </property>
            <property name="toolTip">
             <string>Charge les 3 millésimes CoSIA (2017-2020, 2021-2023, 2024-2026) via le WMS IGN Géoplateforme&#10;Licence Ouverte 2.0 (Etalab) — © IGN</string>
            </property>
           </widget>
          </item>
          <item>
           <spacer name="spacerActuels">
            <property name="orientation"><enum>Qt::Vertical</enum></property>
            <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
           </spacer>
          </item>
         </layout>
        </widget>
        <!-- Onglet Historiques -->
        <widget class="QWidget" name="tabHistoriques">
         <attribute name="title">
          <string>Historiques</string>
         </attribute>
         <layout class="QVBoxLayout" name="layoutHistoriques">
          <property name="spacing">
           <number>4</number>
          </property>
          <property name="leftMargin"><number>8</number></property>
          <property name="topMargin"><number>6</number></property>
          <property name="rightMargin"><number>8</number></property>
          <property name="bottomMargin"><number>6</number></property>
          <item>
           <widget class="QCheckBox" name="chkPhotoAeriennes">
            <property name="text">
             <string>Photographies aériennes historiques...</string>
            </property>
            <property name="toolTip">
             <string>Ouvre une fenêtre de sélection des photographies aériennes historiques IGN (1950-2023)&#10;Licence Ouverte 2.0 (Etalab) — © IGN</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkScan50_1950">
            <property name="text">
             <string>SCAN 50® 1950 IGN</string>
            </property>
            <property name="toolTip">
             <string>Charge le SCAN 50 de 1950 depuis la Géoplateforme IGN&#10;Licence Ouverte 2.0 (Etalab) — © IGN</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkScanCassini">
            <property name="text">
             <string>Carte de Cassini IGN (XVIIIe siècle)</string>
            </property>
            <property name="toolTip">
             <string>Charge le scan de la carte de Cassini (première carte de France au 1/86400e, XVIIIe siècle) depuis la Géoplateforme IGN&#10;Domaine public — scan © IGN (Licence Ouverte 2.0)</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="chkScanEtatMajor">
            <property name="text">
             <string>Carte d'État-Major IGN (1820-1866)</string>
            </property>
            <property name="toolTip">
             <string>Charge le scan de la carte d'État-Major (relevés entre 1820 et 1866) depuis la Géoplateforme IGN&#10;Domaine public — scan © IGN (Licence Ouverte 2.0)</string>
            </property>
           </widget>
          </item>
          <item>
           <spacer name="spacerHistoriques">
            <property name="orientation"><enum>Qt::Vertical</enum></property>
            <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
           </spacer>
          </item>
         </layout>
        </widget>
        <!-- Onglet Autres (vide) -->
        <widget class="QWidget" name="tabAutres">
         <attribute name="title">
          <string>Autres</string>
         </attribute>
         <layout class="QVBoxLayout" name="layoutAutres">
          <property name="leftMargin"><number>8</number></property>
          <property name="topMargin"><number>6</number></property>
          <property name="rightMargin"><number>8</number></property>
          <property name="bottomMargin"><number>6</number></property>
          <item>
           <spacer name="spacerAutres">
            <property name="orientation"><enum>Qt::Vertical</enum></property>
            <property name="sizeHint" stdset="0"><size><width>0</width><height>40</height></size></property>
           </spacer>
          </item>
         </layout>
        </widget>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="btnLoadCadastre">
        <property name="text">
         <string>Charger les données</string>
        </property>
        <property name="toolTip">
         <string>Charge les données sélectionnées pour le code INSEE saisi</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <spacer name="verticalSpacer">
